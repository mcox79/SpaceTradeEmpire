; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Space Trade Empire"
config/version="1.0.0"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")

[autoload]

GameManager="res://scripts/core/game_manager.gd"
SimBridge="res://scripts/bridge/SimBridge.cs"
DebugMenu="*res://addons/debug_menu/debug_menu.tscn"
TooltipManager="*res://addons/tooltips_pro/scripts/tooltip_manager.gd"
TooltipPlaceholderVariables="*res://addons/tooltips_pro/scripts/tooltip_placeholder_variables.gd"
TooltipLinkData="*res://addons/tooltips_pro/scripts/tooltip_link_data.gd"
ToastManager="*res://scripts/ui/toast_manager.gd"
UITheme="*res://scripts/ui/ui_theme.gd"
MusicManager="*res://scripts/audio/music_manager.gd"
CombatAudio="*res://scripts/audio/combat_audio.gd"
SettingsManager="*res://scripts/core/settings_manager.gd"
InputManager="*res://scripts/core/input_manager.gd"
ColorblindFilter="*res://scripts/view/colorblind_filter.gd"
FirstLaunchPanel="*res://scripts/ui/first_launch_panel.gd"
SteamInterface="*res://scripts/platform/steam_interface.gd"
VOLookup="*res://scripts/audio/vo_lookup.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Space Trade Empire"

[editor_plugins]

enabled=PackedStringArray("res://addons/debug_menu/plugin.cfg", "res://addons/tooltips_pro/plugin.cfg")

[filesystem]

import/blender/enabled=false

